{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(docker pull *)",
      "Bash(docker run *)",
      "Bash(rtk *)",
      "Skill(update-config)",
      "mcp__github",
      "mcp__obsidian",
      "mcp__fetch",
      "mcp__context7",
      "mcp__sequentialthinking",
      "mcp__gitlab",
      "mcp__dockerhub__check*",
      "mcp__dockerhub__get*",
      "mcp__dockerhub__list*",
      "mcp__dockerhub__search",
      "mcp__dockerhub__dockerHardenedImages",
      "mcp__filesystem__read_*",
      "mcp__filesystem__list_*",
      "mcp__filesystem__search_*",
      "mcp__filesystem__get_*",
      "mcp__filesystem__directory_tree",
      "mcp__plugin_engram_engram__mem_save",
      "mcp__plugin_engram_engram__mem_search",
      "mcp__plugin_engram_engram__mem_context",
      "mcp__plugin_engram_engram__mem_session_summary",
      "mcp__plugin_engram_engram__mem_get_observation",
      "mcp__plugin_engram_engram__mem_save_prompt",
      "mcp__plugin_engram_engram__mem_update",
      "mcp__plugin_engram_engram__mem_suggest_topic_key",
      "mcp__plugin_engram_engram__mem_session_start",
      "mcp__plugin_engram_engram__mem_session_end",
      "mcp__plugin_engram_engram__mem_stats",
      "mcp__plugin_engram_engram__mem_delete",
      "mcp__plugin_engram_engram__mem_timeline",
      "mcp__plugin_engram_engram__mem_capture_passive"
    ],
    "deny": [
      "mcp__gitlab__approve_*",
      "mcp__gitlab__unapprove_*",
      "mcp__gitlab__bulk_*",
      "mcp__gitlab__cancel_*",
      "mcp__gitlab__create_*",
      "mcp__gitlab__delete_*",
      "mcp__gitlab__edit_*",
      "mcp__gitlab__fork_*",
      "mcp__gitlab__merge_*",
      "mcp__gitlab__play_*",
      "mcp__gitlab__promote_*",
      "mcp__gitlab__publish_*",
      "mcp__gitlab__push_*",
      "mcp__gitlab__resolve_*",
      "mcp__gitlab__retry_*",
      "mcp__gitlab__update_*",
      "mcp__gitlab__upload_*",
      "mcp__gitlab__*variable*"
    ]
  },
  "model": "opus",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh /Users/filipp.vysokov/.claude/hooks/obsidian-index.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "sh /Users/filipp.vysokov/.claude/auto-sync.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_response.filePath // .tool_input.file_path'); echo \"$f\" | grep -qE '\\.(yml|yaml)$' && echo \"$f\" | grep -qE '(roles/|playbooks/|tasks/|handlers/|defaults/|vars/|group_vars/|host_vars/|playbook|ansible)' && [ -f .venv/bin/ansible-lint ] && .venv/bin/ansible-lint \"$f\" 2>/dev/null || true",
            "timeout": 60,
            "statusMessage": "Running ansible-lint..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_response.filePath // .tool_input.file_path'); echo \"$f\" | grep -qE '\\.(tf|tfvars)$' && terraform fmt \"$f\" 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Running terraform fmt..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh /Users/filipp.vysokov/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "remember@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "engram@engram": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "engram": {
      "source": {
        "source": "github",
        "repo": "Gentleman-Programming/engram"
      }
    }
  },
  "tui": "fullscreen"
}
