{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh /Users/filipp.vysokov/.claude/hooks/obsidian-index.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "sh /Users/filipp.vysokov/.claude/auto-sync.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_response.filePath // .tool_input.file_path'); echo \"$f\" | grep -qE '\\.(yml|yaml)$' && echo \"$f\" | grep -qE '(roles/|playbooks/|tasks/|handlers/|defaults/|vars/|group_vars/|host_vars/|playbook|ansible)' && [ -f .venv/bin/ansible-lint ] && .venv/bin/ansible-lint \"$f\" 2>/dev/null || true",
            "timeout": 60,
            "statusMessage": "Running ansible-lint..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_response.filePath // .tool_input.file_path'); echo \"$f\" | grep -qE '\\.(tf|tfvars)$' && terraform fmt \"$f\" 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Running terraform fmt..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(docker pull:*)",
      "Bash(docker run:*)",
      "Skill(update-config)",

      "mcp__github",
      "mcp__obsidian",
      "mcp__fetch",
      "mcp__context7",
      "mcp__sequentialthinking",

      "mcp__gitlab__get_*",
      "mcp__gitlab__list_*",
      "mcp__gitlab__search_*",
      "mcp__gitlab__my_*",
      "mcp__gitlab__verify_namespace",
      "mcp__gitlab__download_attachment",
      "mcp__gitlab__download_job_artifacts",
      "mcp__gitlab__download_release_asset",
      "mcp__gitlab__mr_discussions",

      "mcp__dockerhub__check*",
      "mcp__dockerhub__get*",
      "mcp__dockerhub__list*",
      "mcp__dockerhub__search",
      "mcp__dockerhub__dockerHardenedImages",

      "mcp__filesystem__read_*",
      "mcp__filesystem__list_*",
      "mcp__filesystem__search_*",
      "mcp__filesystem__get_*",
      "mcp__filesystem__directory_tree"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh /Users/filipp.vysokov/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "remember@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  }
}
