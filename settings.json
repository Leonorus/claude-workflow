{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(docker pull *)",
      "Bash(docker run *)",
      "Bash(rtk *)",
      "Bash(find *)",
      "Bash(python3 *)",
      "Bash(brew list *)",
      "Bash(brew info *)",
      "Bash(brew tap *)",
      "Bash(launchctl list *)",
      "Bash(crontab -l)",
      "Bash(log show *)",
      "Skill(update-config)",
      "mcp__gitlab",
      "mcp__workflow",
      "mcp__docker_gateway__fetch",
      "mcp__docker_gateway__resolve_library_id",
      "mcp__docker_gateway__get_library_docs",
      "mcp__docker_gateway__resolve-library-id",
      "mcp__docker_gateway__get-library-docs",
      "mcp__docker_gateway__search*",
      "mcp__docker_gateway__list*",
      "mcp__docker_gateway__get*",
      "mcp__docker_gateway__check*",
      "mcp__docker_gateway__read*",
      "mcp__docker_gateway__directory_tree",
      "mcp__docker_gateway__issue_read",
      "mcp__docker_gateway__pull_request_read",
      "mcp__docker_gateway__dockerHardenedImages",
      "mcp__docker_gateway__obsidian_get*",
      "mcp__docker_gateway__obsidian_list*",
      "mcp__docker_gateway__obsidian_simple_search",
      "mcp__docker_gateway__obsidian_complex_search"
    ],
    "deny": [
      "mcp__gitlab__approve_*",
      "mcp__gitlab__unapprove_*",
      "mcp__gitlab__bulk_*",
      "mcp__gitlab__cancel_*",
      "mcp__gitlab__create_*",
      "mcp__gitlab__delete_*",
      "mcp__gitlab__edit_*",
      "mcp__gitlab__fork_*",
      "mcp__gitlab__merge_*",
      "mcp__gitlab__play_*",
      "mcp__gitlab__promote_*",
      "mcp__gitlab__publish_*",
      "mcp__gitlab__push_*",
      "mcp__gitlab__resolve_*",
      "mcp__gitlab__retry_*",
      "mcp__gitlab__update_*",
      "mcp__gitlab__upload_*",
      "mcp__gitlab__*variable*",
      "mcp__docker_gateway__createRepository",
      "mcp__docker_gateway__updateRepositoryInfo",
      "mcp__docker_gateway__delete_*",
      "mcp__docker_gateway__create_*",
      "mcp__docker_gateway__update_*",
      "mcp__docker_gateway__fork_*",
      "mcp__docker_gateway__merge_*",
      "mcp__docker_gateway__push_*",
      "mcp__docker_gateway__upload_*",
      "mcp__docker_gateway__*variable*",
      "mcp__docker_gateway__write_file",
      "mcp__docker_gateway__edit_file",
      "mcp__docker_gateway__move_file",
      "mcp__docker_gateway__create_directory",
      "mcp__docker_gateway__obsidian_append_content",
      "mcp__docker_gateway__obsidian_patch_content",
      "mcp__docker_gateway__obsidian_delete_file",
      "mcp__docker_gateway__mcp_add",
      "mcp__docker_gateway__mcp_remove",
      "mcp__docker_gateway__mcp_config_set",
      "mcp__docker_gateway__mcp_activate_profile",
      "mcp__docker_gateway__mcp_create_profile"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh /Users/filipp.vysokov/.claude/hooks/obsidian-index.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "sh /Users/filipp.vysokov/.claude/auto-sync.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_response.filePath // .tool_input.file_path'); echo \"$f\" | grep -qE '\\.(yml|yaml)$' && echo \"$f\" | grep -qE '(roles/|playbooks/|tasks/|handlers/|defaults/|vars/|group_vars/|host_vars/|playbook|ansible)' && [ -f .venv/bin/ansible-lint ] && .venv/bin/ansible-lint \"$f\" 2>/dev/null || true",
            "timeout": 60,
            "statusMessage": "Running ansible-lint..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_response.filePath // .tool_input.file_path'); echo \"$f\" | grep -qE '\\.(tf|tfvars)$' && terraform fmt \"$f\" 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Running terraform fmt..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh /Users/filipp.vysokov/.claude/hooks/classify-task-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh /Users/filipp.vysokov/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "remember@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "tui": "fullscreen",
  "model": "opus"
}
