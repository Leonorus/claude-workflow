# Allowlist strategy: ignore everything, then explicitly permit the files
# that make up the public workflow. Any new session data or cache written
# by Claude Code in the future stays out of the repo by default.

# --- Ignore everything by default ---
*

# --- Explicitly allow the public workflow files ---
!.gitignore
!README.md
!LICENSE
!CLAUDE.md
!RTK.md
!settings.json
!mcp.json
!statusline-command.sh
!auto-sync.sh
!install.sh

# Allow the skills directory and nested SKILL.md files
!skills/
!skills/*/
!skills/*/SKILL.md
!skills/**/references/
!skills/**/references/*.md

# Allow the hooks directory and shell scripts inside it
!hooks/
!hooks/*.sh

# Allow custom agent definitions (referenced by classify-task dispatch rules)
!agents/
!agents/*.md

# Allow scheduled-tasks (launchd jobs) — each with its SKILL.md, run.sh, and plist.
# Per-task logs/ and transient state are blocked by the default `*` rule.
!scheduled-tasks/
!scheduled-tasks/*/
!scheduled-tasks/*/SKILL.md
!scheduled-tasks/*/run.sh
!scheduled-tasks/*/*.plist
!scheduled-tasks/*/*.py

# --- Hard-block things that must never leak, even if the above allowlist
# would otherwise include them ---
CLAUDE.md.bak*
*.bak
*.bak-*
settings.local.json
session-env/
sessions/
history.jsonl
.DS_Store
